# Copy to .env and fill in from Lovable Cloud → Connect Supabase.
# The anon/publishable key is safe to expose in the browser bundle.
# NEVER put the service-role key in a VITE_ variable — it must stay server-only.

SUPABASE_PROJECT_ID=""
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY=""

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Server-only (edge functions / SSR). Do NOT prefix with VITE_.
# SUPABASE_SERVICE_ROLE_KEY=""
